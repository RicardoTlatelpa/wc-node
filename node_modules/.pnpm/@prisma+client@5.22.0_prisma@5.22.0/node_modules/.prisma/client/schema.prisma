generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Page {
  id          String       @id @default(cuid())
  url         String       @unique
  domain      String
  statusCode  Int?
  contentType String?
  fetchedAt   DateTime?
  hash        String?
  storageKey  String?
  linksOut    Link[]
  crawls      CrawlEvent[]

  @@index([domain])
  @@index([hash])
}

model Link {
  id     String  @id @default(cuid())
  fromId String
  toUrl  String
  rel    String?

  from Page @relation(fields: [fromId], references: [id])

  @@index([toUrl])
  @@index([fromId])
}

model Crawl {
  id            String       @id @default(cuid())
  seedUrl       String
  status        CrawlStatus  @default(RUNNING)
  createdAt     DateTime     @default(now())
  finishedAt    DateTime?
  maxPages      Int          @default(10000)
  scope         Scope        @default(DOMAIN)
  robotsRespect Boolean      @default(true)
  events        CrawlEvent[]
}

enum CrawlStatus {
  RUNNING
  PAUSED
  FINISHED
  FAILED
}

enum Scope {
  DOMAIN
  SUBTREE
  GLOBAL
}

model CrawlEvent {
  id      String   @id @default(cuid())
  crawlId String
  pageId  String?
  type    String
  at      DateTime @default(now())
  message String?

  crawl Crawl @relation(fields: [crawlId], references: [id])
  page  Page? @relation(fields: [pageId], references: [id])

  @@index([crawlId, at])
  @@index([pageId])
}

model Dedupe {
  urlHash   String   @id
  url       String
  firstSeen DateTime @default(now())
}
