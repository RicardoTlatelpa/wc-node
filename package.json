{
  "name": "web-crawler",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm -F @crawler/api dev",
    "dev:worker": "pnpm -F @crawler/worker dev",
    "migrate": "pnpm dlx prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "prisma:generate": "pnpm dlx prisma generate --schema packages/db/prisma/schema.prisma"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prisma": "^5.17.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.46.1",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@prisma/client": "^5.17.0",
    "bullmq": "^5.9.0",
    "cheerio": "^1.0.0-rc.12",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "node-fetch": "^3.3.2",
    "pino": "^9.0.0",
    "robots-parser": "^3.0.1",
    "zod": "^3.23.8"
  }
}
