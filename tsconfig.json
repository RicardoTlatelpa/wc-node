{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@crawler/contracts/*": ["packages/contracts/src/*"],
      "@crawler/queue/*": ["packages/queue/src/*"],
      "@crawler/shared/*": ["packages/shared/src/*"],
      "@crawler/db/*": ["packages/db/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
